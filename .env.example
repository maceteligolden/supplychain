# When "true", Next.js API routes serve mock data. Set to "false" to proxy to real backend.
NEXT_PUBLIC_USE_MOCK_API=true

# Real backend base URL used by API route proxy handlers (server-side only).
API_PROXY_TARGET=

# Simulated network delay for mock API responses (milliseconds).
MOCK_DELAY_MS=200

# Public app URL for server-side fetch to internal API routes.
# Local: http://localhost:3000
# Netlify: https://your-site.netlify.app (optional — URL is auto-detected from Netlify env)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session cookie configuration (server-side).
SESSION_COOKIE_NAME=sc_session
SESSION_MAX_AGE_SECONDS=86400
SESSION_SECRET=traceability-poc-dev-secret-change-in-production
